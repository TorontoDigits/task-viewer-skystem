{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["es2017", "dom", "es2016", "es2015"],
    "strict": false,
    "module": "es2015",
    "outDir": "./dist",
    "rootDir": "./",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": false,
    "noEmitOnError": false,
    "removeComments": false
  },
  "include": ["*.ts", "*.js"],
  "exclude": ["node_modules", "dist"]
}